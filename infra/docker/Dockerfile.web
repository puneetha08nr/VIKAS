FROM node:20-alpine

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Copy entire repository
COPY . .

# Move to web app
WORKDIR /app/apps/web

# Install dependencies
RUN pnpm install --frozen-lockfile

# Build Next.js app
RUN pnpm build

EXPOSE 3000

# Production start
CMD ["pnpm", "start"]