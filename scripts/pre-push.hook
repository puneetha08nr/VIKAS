#!/bin/sh
# Mirrors the three CI jobs. Blocks push if any check fails.
set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT/apps/api"

echo "→ ruff lint..."
uv run ruff check .

echo "→ pyright type check..."
uv run pyright .

echo "→ unit tests..."
uv run pytest ../../tests/unit/ -q --tb=short

echo "✓ All checks passed — pushing."
