# ============================================================
# Vikas AI Marketing Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Local dev uses the Docker Compose credentials below.
# Change the host/credentials for staging/prod.
DATABASE_URL=postgresql+asyncpg://vikas:vikas_dev@localhost:5432/vikas
REDIS_URL=redis://localhost:6379/0

# ── LLM Providers ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIzaSy...
OPENROUTER_API_KEY=sk-or-...

# ── Google Search Console ─────────────────────────────────────
# Paste the full JSON of your GSC service account key
GSC_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GSC_SITE_URL=https://yourdomain.com

# ── Google Analytics 4 ───────────────────────────────────────
GA4_PROPERTY_ID=1234567890
GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── WordPress ─────────────────────────────────────────────────
WORDPRESS_URL=https://yourblog.com
# Generate at: Users → Security → Application Passwords
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── SEO Data Providers (pick one or both) ────────────────────
AHREFS_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── Auth — Supabase ───────────────────────────────────────────
SUPABASE_URL=https://exewnvggfrcfnyhsdxrp.supabase.co
SUPABASE_ANON_KEY=sb_publishable_DeqUIRBuntumxQJRQjUNoA_j2HAIIfN
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Storage — S3 / GCS ───────────────────────────────────────
S3_BUCKET=vikas-media
AWS_REGION=us-east-1
